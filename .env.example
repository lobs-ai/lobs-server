# Lobs Server Environment Configuration
# Copy this file to `.env` and customize as needed
# All settings are optional — defaults are production-ready

# ============================================
# DATABASE
# ============================================

# SQLite database file location
# Default: ./data/lobs.db
DATABASE_PATH=./data/lobs.db

# ============================================
# ORCHESTRATOR (Built-in Task Runner)
# ============================================

# Enable/disable automatic task orchestration
# Default: true
ORCHESTRATOR_ENABLED=true

# How often (in seconds) to check for new tasks
# Default: 10
ORCHESTRATOR_POLL_INTERVAL=10

# Maximum concurrent worker agents
# Default: 3
ORCHESTRATOR_MAX_WORKERS=3

# ============================================
# OPENCLAW GATEWAY (Agent Execution)
# ============================================

# OpenClaw Gateway URL for spawning agents
# Default: http://127.0.0.1:18789
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789

# OpenClaw Gateway authentication token
# Default: (test token — replace in production)
OPENCLAW_GATEWAY_TOKEN=341c3e8015df9c77f6ed4cba1359403135994364caf7c668

# Base directory for Lobs projects (lobs-server, lobs-mission-control, etc.)
# Default: User's home directory
LOBS_PROJECTS_DIR=/Users/yourusername

# Agent files directory (AGENTS.md, SOUL.md, TOOLS.md templates)
# Default: ~/lobs-orchestrator/agents
AGENT_FILES_DIR=/Users/yourusername/lobs-orchestrator/agents

# ============================================
# BACKUPS
# ============================================

# Enable automatic database backups
# Default: true
BACKUP_ENABLED=true

# Backup frequency in hours
# Default: 6 (every 6 hours)
BACKUP_INTERVAL_HOURS=6

# Number of backup files to retain
# Default: 30
BACKUP_RETENTION_COUNT=30

# Backup storage directory
# Default: ./data/backups
BACKUP_DIR=./data/backups

# Enable git-based backup (commits backups to git repo)
# Default: false
BACKUP_GIT_ENABLED=false

# ============================================
# LOGGING
# ============================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
LOG_LEVEL=INFO

# Log output format: console (human-readable) or json (structured)
# Default: console
LOG_FORMAT=console

# Directory for log files
# Default: ./logs
LOG_DIR=./logs

# ============================================
# NOTES
# ============================================
# - All paths support ~ for home directory expansion
# - Boolean values: true/false, 1/0, yes/no (case-insensitive)
# - Changes require server restart to take effect
# - No .env file needed if defaults are acceptable
